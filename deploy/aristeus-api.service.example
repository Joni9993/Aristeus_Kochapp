# /etc/systemd/system/aristeus-api.service
#
# Aristeus FastAPI backend via Uvicorn.
#
# Setup:
#   sudo cp aristeus-api.service.example /etc/systemd/system/aristeus-api.service
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now aristeus-api

[Unit]
Description=Aristeus Kochapp API (FastAPI / Uvicorn)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=aristeus
Group=aristeus
WorkingDirectory=/opt/aristeus/app
Environment=PYTHONUNBUFFERED=1
EnvironmentFile=/opt/aristeus/.env
ExecStart=/opt/aristeus/app/.venv/bin/uvicorn app.main:app \
    --host 127.0.0.1 \
    --port 8000 \
    --proxy-headers \
    --forwarded-allow-ips=127.0.0.1
Restart=on-failure
RestartSec=3

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/aristeus/data

[Install]
WantedBy=multi-user.target
