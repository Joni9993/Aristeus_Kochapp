# Copy to .env and fill in your own values

# General
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string

# Database
DATABASE_URL=sqlite:///./data/aristeus.db

# CORS (comma-separated list of allowed frontend origins)
ALLOWED_ORIGINS=http://localhost:5173

# OpenRouter — default is tried first; fallbacks are comma-separated, tried in order
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_DEFAULT_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_FALLBACK_MODELS=google/gemma-4-31b-it:free,meta-llama/llama-3.3-70b-instruct:free,nvidia/nemotron-3-super-120b-a12b:free

# Chefkoch recipe catalog is deactivated by default — AI is the primary source
USE_RECIPE_CATALOG=false

# Optional paid fallback models (comma-separated), appended after the free
# fallback chain (both retry rounds). Empty = today's free-only chain.
OPENROUTER_PAID_MODELS=

# Optional status-dashboard webhook (Kuma-format JSON). Gets an incident entry
# ("Letzte Vorfälle" + Web Push) on plan-generation failures and from the
# Monday 07:00 pre-generation healthcheck. Production value:
# STATUS_WEBHOOK_URL=http://192.168.50.62:8080/api/kuma-webhook
# Empty = incidents are only logged.
STATUS_WEBHOOK_URL=

# Optional Pexels API key (free, get one at https://www.pexels.com/api/) for
# dish photos on suggestion cards + recipes. Empty = no image search, dishes
# just show a placeholder.
PEXELS_API_KEY=

# E-Mail (SMTP) — for password reset
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Aristeus <noreply@example.com>

# Public URL of the deployed frontend (used in e-mail links)
PUBLIC_FRONTEND_URL=http://localhost:5173
