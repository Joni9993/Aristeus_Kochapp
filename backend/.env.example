# Copy to .env and fill in your own values

# General
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string

# Database
DATABASE_URL=sqlite:///./data/aristeus.db

# CORS (comma-separated list of allowed frontend origins)
ALLOWED_ORIGINS=http://localhost:5173

# OpenRouter — default is tried first; fallbacks are comma-separated, tried in order
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_DEFAULT_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_FALLBACK_MODELS=google/gemma-4-31b-it:free,meta-llama/llama-3.3-70b-instruct:free,nvidia/nemotron-3-super-120b-a12b:free

# Chefkoch recipe catalog is deactivated by default — AI is the primary source
USE_RECIPE_CATALOG=false

# E-Mail (SMTP) — for password reset
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Aristeus <noreply@example.com>

# Public URL of the deployed frontend (used in e-mail links)
PUBLIC_FRONTEND_URL=http://localhost:5173
